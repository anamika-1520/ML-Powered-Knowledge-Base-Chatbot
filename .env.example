# Example environment variables for the Car Price Chatbot
# Copy this file to .env and fill in the values before running.

# Example environment variables for the Car Price Chatbot
# Copy this file to .env and fill in the values before running locally.

# Groq API key for ChatGroq-based model access
GROQ_API_KEY=

# Optional Hugging Face token if HuggingFaceEmbeddings requires authentication
HUGGINGFACEHUB_ACCESS_TOKEN=

# Optional LangChain API key if you use LangChain hosted services
LANGCHAIN_API_KEY=
